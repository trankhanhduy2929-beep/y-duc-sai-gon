<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Máy Tính Sức Khỏe Pro - Tính Tuổi & BMI</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- Phosphor Icons -->
    <script src="https://unpkg.com/@phosphor-icons/web"></script>
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
        .tab-btn.active {
            color: #4f46e5; /* indigo-600 */
            border-bottom: 2px solid #4f46e5;
            font-weight: 600;
        }
        .glass-panel {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
        }
        /* Hide scrollbar for clean UI */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
        
        .fade-in {
            animation: fadeIn 0.4s ease-in-out;
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body class="bg-gradient-to-br from-indigo-50 via-blue-50 to-purple-50 min-h-screen text-slate-800 p-4 sm:p-8 flex items-center justify-center">

    <div class="max-w-3xl w-full glass-panel rounded-3xl shadow-2xl overflow-hidden border border-white/40">
        
        <!-- Header -->
        <div class="bg-indigo-600 p-6 text-white text-center relative overflow-hidden">
            <div class="absolute top-0 left-0 w-full h-full bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-10"></div>
            <h1 class="text-3xl font-bold mb-2 relative z-10 flex items-center justify-center gap-2">
                <i class="ph ph-heartbeat text-4xl text-rose-300"></i>
                Chăm Sóc Sức Khỏe Pro
            </h1>
            <p class="text-indigo-100 relative z-10 text-sm sm:text-base">Công cụ tính toán cá nhân hiện đại và chính xác</p>
        </div>

        <!-- Navigation Tabs -->
        <div class="flex border-b border-gray-200 px-6 pt-4 bg-white">
            <button onclick="switchTab('age')" id="tab-age" class="tab-btn active px-6 py-3 text-gray-500 hover:text-indigo-600 transition-colors flex items-center gap-2">
                <i class="ph ph-calendar-blank text-xl"></i> Tính Tuổi
            </button>
            <button onclick="switchTab('bmi')" id="tab-bmi" class="tab-btn px-6 py-3 text-gray-500 hover:text-indigo-600 transition-colors flex items-center gap-2">
                <i class="ph ph-scales text-xl"></i> Tính BMI Nâng Cao
            </button>
        </div>

        <div class="p-6 sm:p-8 bg-white/50">
            
            <!-- ================= AGE CALCULATOR ================= -->
            <div id="age-section" class="fade-in block">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">Ngày sinh của bạn</label>
                        <input type="date" id="dob" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-shadow outline-none text-gray-700 font-medium">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">Tính đến ngày</label>
                        <input type="date" id="target-date" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-shadow outline-none text-gray-700 font-medium">
                    </div>
                </div>
                
                <button onclick="calculateAge()" class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-4 rounded-xl shadow-lg hover:shadow-indigo-500/30 transition-all flex items-center justify-center gap-2 text-lg">
                    <i class="ph ph-calculator"></i> Tính Tuổi Ngay
                </button>

                <!-- Age Result -->
                <div id="age-result" class="mt-8 hidden fade-in">
                    <div class="bg-gradient-to-r from-indigo-50 to-blue-50 border border-indigo-100 rounded-2xl p-6 text-center mb-6 shadow-sm">
                        <p class="text-gray-500 mb-2 text-sm uppercase tracking-wider font-semibold">Tuổi chính xác của bạn là</p>
                        <div class="flex items-center justify-center gap-2 sm:gap-4 flex-wrap">
                            <div class="text-center">
                                <span id="res-years" class="text-4xl sm:text-5xl font-bold text-indigo-700">0</span>
                                <p class="text-indigo-900/70 font-medium mt-1">Năm</p>
                            </div>
                            <span class="text-3xl text-indigo-300 font-light px-2">,</span>
                            <div class="text-center">
                                <span id="res-months" class="text-4xl sm:text-5xl font-bold text-indigo-700">0</span>
                                <p class="text-indigo-900/70 font-medium mt-1">Tháng</p>
                            </div>
                            <span class="text-3xl text-indigo-300 font-light px-2">,</span>
                            <div class="text-center">
                                <span id="res-days" class="text-4xl sm:text-5xl font-bold text-indigo-700">0</span>
                                <p class="text-indigo-900/70 font-medium mt-1">Ngày</p>
                            </div>
                        </div>
                    </div>

                    <h3 class="text-lg font-semibold text-slate-800 mb-4 flex items-center gap-2">
                        <i class="ph ph-chart-pie-slice text-indigo-500"></i> Thông tin chi tiết
                    </h3>
                    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
                        <div class="bg-white p-4 rounded-xl border border-slate-100 shadow-sm text-center">
                            <p class="text-slate-500 text-xs mb-1">Tổng số tháng</p>
                            <p id="tot-months" class="text-xl font-bold text-slate-700">0</p>
                        </div>
                        <div class="bg-white p-4 rounded-xl border border-slate-100 shadow-sm text-center">
                            <p class="text-slate-500 text-xs mb-1">Tổng số tuần</p>
                            <p id="tot-weeks" class="text-xl font-bold text-slate-700">0</p>
                        </div>
                        <div class="bg-white p-4 rounded-xl border border-slate-100 shadow-sm text-center">
                            <p class="text-slate-500 text-xs mb-1">Tổng số ngày</p>
                            <p id="tot-days" class="text-xl font-bold text-slate-700">0</p>
                        </div>
                        <div class="bg-white p-4 rounded-xl border border-slate-100 shadow-sm text-center">
                            <p class="text-slate-500 text-xs mb-1">Sinh nhật tới</p>
                            <p id="next-bday" class="text-lg font-bold text-indigo-600">0 ngày</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ================= BMI CALCULATOR ================= -->
            <div id="bmi-section" class="hidden fade-in">
                <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
                    <div class="col-span-2 md:col-span-1">
                        <label class="block text-sm font-medium text-gray-700 mb-2">Giới tính</label>
                        <div class="flex rounded-xl bg-gray-100 p-1">
                            <button id="btn-male" onclick="setGender('male')" class="flex-1 py-2 rounded-lg bg-white shadow text-indigo-600 font-medium text-sm transition-all flex items-center justify-center gap-1">
                                <i class="ph ph-gender-male"></i> Nam
                            </button>
                            <button id="btn-female" onclick="setGender('female')" class="flex-1 py-2 rounded-lg text-gray-500 hover:text-gray-700 font-medium text-sm transition-all flex items-center justify-center gap-1">
                                <i class="ph ph-gender-female"></i> Nữ
                            </button>
                        </div>
                    </div>
                    <div class="col-span-2 md:col-span-1">
                        <label class="block text-sm font-medium text-gray-700 mb-2">Tuổi (Năm)</label>
                        <input type="number" id="bmi-age" value="25" min="2" max="120" class="w-full px-4 py-2.5 rounded-xl border border-gray-300 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none">
                    </div>
                    <div class="col-span-2 md:col-span-1">
                        <label class="block text-sm font-medium text-gray-700 mb-2">Chiều cao (cm)</label>
                        <input type="number" id="bmi-height" placeholder="Ví dụ: 170" class="w-full px-4 py-2.5 rounded-xl border border-gray-300 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none">
                    </div>
                    <div class="col-span-2 md:col-span-1">
                        <label class="block text-sm font-medium text-gray-700 mb-2">Cân nặng (kg)</label>
                        <input type="number" id="bmi-weight" placeholder="Ví dụ: 65" class="w-full px-4 py-2.5 rounded-xl border border-gray-300 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none">
                    </div>
                </div>

                <button onclick="calculateBMI()" class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-4 rounded-xl shadow-lg hover:shadow-indigo-500/30 transition-all flex items-center justify-center gap-2 text-lg">
                    <i class="ph ph-activity"></i> Phân Tích Chỉ Số
                </button>

                <!-- BMI Result -->
                <div id="bmi-result" class="mt-8 hidden fade-in">
                    <div class="bg-white border border-gray-100 rounded-2xl p-6 shadow-sm mb-6">
                        <div class="flex flex-col md:flex-row items-center justify-between gap-6">
                            <div class="text-center md:text-left flex-1">
                                <p class="text-gray-500 text-sm font-semibold uppercase tracking-wider mb-1">Chỉ số BMI của bạn</p>
                                <div class="flex items-baseline justify-center md:justify-start gap-3">
                                    <span id="res-bmi" class="text-5xl font-black text-slate-800">0.0</span>
                                    <span id="res-bmi-cat" class="px-3 py-1 rounded-full text-sm font-bold bg-green-100 text-green-700">Bình thường</span>
                                </div>
                            </div>
                            
                            <div class="flex-1 w-full text-sm">
                                <div class="flex justify-between mb-1">
                                    <span class="text-gray-500">Cân nặng lý tưởng:</span>
                                    <span id="res-ideal" class="font-bold text-indigo-600">0 - 0 kg</span>
                                </div>
                                <div class="flex justify-between mb-1">
                                    <span class="text-gray-500">Tỷ lệ mỡ (BFP) ước tính:</span>
                                    <span id="res-bfp" class="font-bold text-rose-500">0%</span>
                                </div>
                                <div class="flex justify-between">
                                    <span class="text-gray-500">Phân loại BFP:</span>
                                    <span id="res-bfp-cat" class="font-semibold text-slate-700">-</span>
                                </div>
                            </div>
                        </div>

                        <!-- Gauge Bar -->
                        <div class="mt-8 relative">
                            <div class="h-3 w-full rounded-full flex overflow-hidden">
                                <div class="h-full bg-blue-400" style="width: 25%" title="Thiếu cân (< 18.5)"></div>
                                <div class="h-full bg-green-400" style="width: 25%" title="Bình thường (18.5 - 24.9)"></div>
                                <div class="h-full bg-yellow-400" style="width: 25%" title="Thừa cân (25 - 29.9)"></div>
                                <div class="h-full bg-red-500" style="width: 25%" title="Béo phì (≥ 30)"></div>
                            </div>
                            <!-- Pointer -->
                            <div id="bmi-pointer" class="absolute top-0 -mt-2 w-0 h-0 border-l-[6px] border-l-transparent border-r-[6px] border-r-transparent border-t-[8px] border-t-slate-800 transition-all duration-700" style="left: 0%;"></div>
                            
                            <div class="flex justify-between text-xs text-gray-400 mt-2 font-medium px-1">
                                <span>15</span>
                                <span>18.5</span>
                                <span>25</span>
                                <span>30</span>
                                <span>40</span>
                            </div>
                        </div>
                    </div>
                    
                    <div class="p-4 bg-blue-50 text-blue-800 rounded-xl text-sm border border-blue-100 flex gap-3">
                        <i class="ph ph-info text-xl shrink-0 mt-0.5"></i>
                        <p id="bmi-advice">Vui lòng nhập thông tin để xem lời khuyên.</p>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <script>
        // Set default dates
        const today = new Date();
        const dateString = today.toISOString().split('T')[0];
        document.getElementById('target-date').value = dateString;
        
        // Default DOB 25 years ago for better initial UX
        const dobDefault = new Date();
        dobDefault.setFullYear(today.getFullYear() - 25);
        document.getElementById('dob').value = dobDefault.toISOString().split('T')[0];

        // Tab Switching Logic
        function switchTab(tab) {
            document.getElementById('age-section').classList.add('hidden');
            document.getElementById('bmi-section').classList.add('hidden');
            document.getElementById('tab-age').classList.remove('active');
            document.getElementById('tab-bmi').classList.remove('active');

            if (tab === 'age') {
                document.getElementById('age-section').classList.remove('hidden');
                document.getElementById('tab-age').classList.add('active');
            } else {
                document.getElementById('bmi-section').classList.remove('hidden');
                document.getElementById('tab-bmi').classList.add('active');
            }
        }

        // --- AGE CALCULATOR LOGIC ---
        function calculateAge() {
            const dobInput = document.getElementById('dob').value;
            const targetInput = document.getElementById('target-date').value;

            if (!dobInput || !targetInput) {
                alert("Vui lòng chọn đầy đủ ngày sinh và ngày đích.");
                return;
            }

            const birthDate = new Date(dobInput);
            const targetDate = new Date(targetInput);

            if (birthDate > targetDate) {
                alert("Ngày sinh không thể lớn hơn ngày đích.");
                return;
            }

            // Calculate Exact Years, Months, Days
            let y1 = birthDate.getFullYear();
            let m1 = birthDate.getMonth();
            let d1 = birthDate.getDate();

            let y2 = targetDate.getFullYear();
            let m2 = targetDate.getMonth();
            let d2 = targetDate.getDate();

            let years = y2 - y1;
            let months = m2 - m1;
            let days = d2 - d1;

            if (days < 0) {
                months--;
                // Get days in previous month of target year
                let prevMonth = m2 === 0 ? 11 : m2 - 1;
                let prevMonthYear = m2 === 0 ? y2 - 1 : y2;
                let daysInPrevMonth = new Date(prevMonthYear, prevMonth + 1, 0).getDate();
                days += daysInPrevMonth;
            }

            if (months < 0) {
                years--;
                months += 12;
            }

            // Calculate Totals
            const diffTime = Math.abs(targetDate - birthDate);
            const totalDays = Math.floor(diffTime / (1000 * 60 * 60 * 24));
            const totalWeeks = Math.floor(totalDays / 7);
            const totalMonths = (years * 12) + months;

            // Calculate next birthday days
            let nextBday = new Date(targetDate.getFullYear(), m1, d1);
            if (nextBday < targetDate) {
                nextBday.setFullYear(targetDate.getFullYear() + 1);
            }
            const daysToNextBday = Math.ceil((nextBday - targetDate) / (1000 * 60 * 60 * 24));

            // Update UI
            animateValue("res-years", 0, years, 1000);
            animateValue("res-months", 0, months, 1000);
            animateValue("res-days", 0, days, 1000);

            document.getElementById('tot-months').innerText = totalMonths.toLocaleString('vi-VN');
            document.getElementById('tot-weeks').innerText = totalWeeks.toLocaleString('vi-VN');
            document.getElementById('tot-days').innerText = totalDays.toLocaleString('vi-VN');
            
            if(daysToNextBday === 0 && (m1===m2 && d1===d2)) {
                document.getElementById('next-bday').innerText = "Hôm nay! 🎉";
            } else {
                document.getElementById('next-bday').innerText = daysToNextBday + " ngày";
            }

            document.getElementById('age-result').classList.remove('hidden');
        }

        // Helper: Number animation
        function animateValue(id, start, end, duration) {
            if (start === end) {
                document.getElementById(id).innerHTML = end;
                return;
            }
            var range = end - start;
            var current = start;
            var increment = end > start? 1 : -1;
            var stepTime = Math.abs(Math.floor(duration / range));
            var obj = document.getElementById(id);
            var timer = setInterval(function() {
                current += increment;
                obj.innerHTML = current;
                if (current == end) {
                    clearInterval(timer);
                }
            }, stepTime);
        }

        // --- BMI CALCULATOR LOGIC ---
        let selectedGender = 'male';

        function setGender(gender) {
            selectedGender = gender;
            const btnMale = document.getElementById('btn-male');
            const btnFemale = document.getElementById('btn-female');
            
            if (gender === 'male') {
                btnMale.className = "flex-1 py-2 rounded-lg bg-white shadow text-indigo-600 font-medium text-sm transition-all flex items-center justify-center gap-1";
                btnFemale.className = "flex-1 py-2 rounded-lg text-gray-500 hover:text-gray-700 font-medium text-sm transition-all flex items-center justify-center gap-1";
            } else {
                btnFemale.className = "flex-1 py-2 rounded-lg bg-white shadow text-pink-600 font-medium text-sm transition-all flex items-center justify-center gap-1";
                btnMale.className = "flex-1 py-2 rounded-lg text-gray-500 hover:text-gray-700 font-medium text-sm transition-all flex items-center justify-center gap-1";
            }
        }

        function calculateBMI() {
            const age = parseFloat(document.getElementById('bmi-age').value);
            const heightCm = parseFloat(document.getElementById('bmi-height').value);
            const weightKg = parseFloat(document.getElementById('bmi-weight').value);

            if (!heightCm || !weightKg || heightCm <= 0 || weightKg <= 0 || !age) {
                alert("Vui lòng nhập đầy đủ Chiều cao, Cân nặng và Tuổi hợp lệ.");
                return;
            }

            const heightM = heightCm / 100;
            const bmi = weightKg / (heightM * heightM);
            
            // Category & Colors
            let category = "";
            let colorClass = "";
            let advice = "";

            if (bmi < 18.5) {
                category = "Thiếu cân";
                colorClass = "bg-blue-100 text-blue-700";
                advice = "Bạn đang thiếu cân. Cần tăng cường dinh dưỡng, ăn đủ các nhóm chất và kết hợp tập luyện nhẹ nhàng để tăng cơ bắp.";
            } else if (bmi >= 18.5 && bmi <= 24.9) {
                category = "Bình thường";
                colorClass = "bg-green-100 text-green-700";
                advice = "Tuyệt vời! Cân nặng của bạn đang ở mức lý tưởng. Hãy duy trì chế độ ăn uống lành mạnh và tập thể dục đều đặn.";
            } else if (bmi >= 25 && bmi <= 29.9) {
                category = "Thừa cân";
                colorClass = "bg-yellow-100 text-yellow-700";
                advice = "Bạn đang bị thừa cân nhẹ. Hãy chú ý giảm lượng calo nạp vào, hạn chế đồ ngọt/dầu mỡ và tăng cường vận động (đi bộ, bơi lội).";
            } else {
                category = "Béo phì";
                colorClass = "bg-red-100 text-red-700";
                advice = "Cảnh báo béo phì! Điều này làm tăng nguy cơ mắc các bệnh tim mạch, tiểu đường. Nên tham khảo ý kiến bác sĩ hoặc chuyên gia dinh dưỡng để có lộ trình giảm cân khoa học.";
            }

            // Ideal Weight (BMI 18.5 to 24.9)
            const minIdeal = (18.5 * heightM * heightM).toFixed(1);
            const maxIdeal = (24.9 * heightM * heightM).toFixed(1);

            // Body Fat Percentage (BFP) Estimate
            // Formula: (1.20 x BMI) + (0.23 x Age) - (10.8 x gender_num) - 5.4
            // gender_num: 1 for male, 0 for female
            const genderNum = selectedGender === 'male' ? 1 : 0;
            let bfp = (1.20 * bmi) + (0.23 * age) - (10.8 * genderNum) - 5.4;
            if(bfp < 2) bfp = 2; // lowest boundary for realism

            // BFP Category
            let bfpCat = "Bình thường";
            if(selectedGender === 'male') {
                if(bfp < 6) bfpCat = "Mỡ thiết yếu (Essential)";
                else if(bfp <= 13) bfpCat = "Vận động viên (Athletes)";
                else if(bfp <= 17) bfpCat = "Thể hình đẹp (Fitness)";
                else if(bfp <= 24) bfpCat = "Chấp nhận được (Average)";
                else bfpCat = "Béo phì (Obese)";
            } else {
                if(bfp < 14) bfpCat = "Mỡ thiết yếu (Essential)";
                else if(bfp <= 20) bfpCat = "Vận động viên (Athletes)";
                else if(bfp <= 24) bfpCat = "Thể hình đẹp (Fitness)";
                else if(bfp <= 31) bfpCat = "Chấp nhận được (Average)";
                else bfpCat = "Béo phì (Obese)";
            }

            // Visual Gauge Pointer Logic
            // Map BMI 15 -> 40 to 0% -> 100%
            let percent = ((bmi - 15) / (40 - 15)) * 100;
            if (percent < 0) percent = 0;
            if (percent > 100) percent = 100;

            // Update UI
            document.getElementById('res-bmi').innerText = bmi.toFixed(1);
            
            const catBadge = document.getElementById('res-bmi-cat');
            catBadge.innerText = category;
            catBadge.className = `px-3 py-1 rounded-full text-sm font-bold ${colorClass}`;
            
            document.getElementById('res-ideal').innerText = `${minIdeal} - ${maxIdeal} kg`;
            document.getElementById('res-bfp').innerText = `${bfp.toFixed(1)}%`;
            document.getElementById('res-bfp-cat').innerText = bfpCat;
            document.getElementById('bmi-advice').innerText = advice;
            
            document.getElementById('bmi-pointer').style.left = `calc(${percent}% - 6px)`;
            
            document.getElementById('bmi-result').classList.remove('hidden');
        }
    </script>
</body>
</html>
